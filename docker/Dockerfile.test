# Terrapod API test runner
# Includes all dev dependencies (pytest, ruff, mypy)

FROM python:3.13-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    jq \
    pkg-config \
    gcc \
    libc6-dev \
    xmlsec1 \
    libxmlsec1-dev \
    libxmlsec1-openssl \
    && rm -rf /var/lib/apt/lists/*

# OPA — so the policy-engine tests (#343) exercise the real binary
# rather than skipping. Kept in sync with docker/Dockerfile.api; both
# pin and verify the same OPA_VERSION + SHA256 so a bump in one without
# the other can't silently land an unverified binary in either image.
ARG TARGETARCH
ARG OPA_VERSION=1.17.0
RUN ARCH="${TARGETARCH:-$(dpkg --print-architecture)}" \
    && BASE="https://github.com/open-policy-agent/opa/releases/download/v${OPA_VERSION}" \
    && curl -fsSL -o /usr/local/bin/opa "${BASE}/opa_linux_${ARCH}_static" \
    && curl -fsSL -o /tmp/opa.sha256 "${BASE}/opa_linux_${ARCH}_static.sha256" \
    && echo "$(cut -d' ' -f1 /tmp/opa.sha256)  /usr/local/bin/opa" | sha256sum -c - \
    && rm /tmp/opa.sha256 \
    && chmod 0755 /usr/local/bin/opa \
    && /usr/local/bin/opa version

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir poetry==1.8.4

WORKDIR /app

# Install ALL dependencies (main + dev)
COPY services/pyproject.toml services/poetry.lock* ./
RUN poetry config virtualenvs.create false \
    && poetry install --no-interaction --no-ansi --no-root

# Copy application and test code
COPY services/terrapod ./terrapod
COPY services/tests ./tests

# Copy the runner entrypoint so tests can exercise its real shell logic
# as a fixture (e.g. the backend-override + post-init backstop tests for
# #346). The entrypoint itself isn't executed here — fragments are
# extracted and run in isolation.
COPY docker/runner-entrypoint.sh ./docker/runner-entrypoint.sh

# Storage data directory for tests
RUN mkdir -p /var/lib/terrapod/storage

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Default: run pytest
CMD ["pytest", "-v", "--tb=short"]
