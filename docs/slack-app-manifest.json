{
  "display_information": {
    "name": "Terrapod",
    "description": "Interactive Terraform run approvals and status from Slack"
  },
  "features": {
    "bot_user": {
      "display_name": "terrapod",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/terrapod",
        "description": "Link your Terrapod account and check link status",
        "usage_hint": "link | status | unlink",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "commands",
        "files:write"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
